#!/bin/bash
set -e

# Calculate CPU utilization on demand
IDLE=$(mpstat 1 1 | tail -n 1 | awk '{print $NF}')
UTIL=$(echo "100 - $IDLE" | bc)
TIMESTAMP=$(date -Is)

# Populate the view for the requester
snapctl set --view :stats-db \
    data.utilization="$UTIL%" \
    data.last-updated="$TIMESTAMP"

echo "load-view-stats-db: Successfully refreshed CPU stats on-demand."

#!/bin/bash
set -e

# --- 1. CPU Utilization (%) ---
IDLE=$(LC_ALL=C mpstat 1 1 | tail -n 1 | awk '{print $NF}')
CPU_UTIL=$(awk -v idle="$IDLE" 'BEGIN { printf "%.0f", 100 - idle }')

# --- 2. RAM Utilization (%) ---
# 'free' outputs memory stats. Divide used ($3) by total ($2) and multiply by 100.
RAM_UTIL=$(free | awk '/Mem:/ {printf "%.0f", $3/$2 * 100}')

# --- 3. Root File System Free (%) ---
# Query the host's root filesystem directly via snapd's hostfs mount
DISK_USED=$(df --output=pcent /var/lib/snapd/hostfs | tail -n 1 | tr -d '% ')
RFS_FREE=$((100 - DISK_USED))

TIMESTAMP=$(date -Is)

# --- 4. Populate the view ---
snapctl set --view :system-stats \
    data.cpu-utilization-percent="$CPU_UTIL" \
    data.ram-utilization-percent="$RAM_UTIL" \
    data.rfs-partition-free-percent="$RFS_FREE" \
    data.last-updated="$TIMESTAMP"

echo "load-view-system-stats: Refreshed stats (CPU: ${CPU_UTIL}%, RAM: ${RAM_UTIL}%, RFS Free: ${RFS_FREE}%)."
